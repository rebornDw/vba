Option Explicit

Sub IF_Jushin_Search_ByInputOrder()

    Dim wbThis As Workbook
    Dim wsInput As Worksheet
    Dim wsOut As Worksheet
    
    Dim wbSrc As Workbook
    Dim wsIndex As Worksheet
    Dim wsDetail As Worksheet
    
    Dim filePath As String
    Dim lastRowInput As Long
    Dim outRow As Long
    Dim i As Long
    
    Dim ifID As String
    Dim dirText As String
    Dim codeText As String
    Dim detailPath As String
    Dim newSheetName As String
    
    '记录每个 IFID 在输入表中出现到第几次
    Dim dictIfCount As Object
    Dim occurIndex As Long
    
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False
    
    On Error GoTo ERR_HANDLE
    
    Set wbThis = ThisWorkbook
    Set wsInput = wbThis.Sheets("Sheet1")
    
    '从 D1 读取目标文件路径
    filePath = Trim(CStr(wsInput.Range("D1").Value))
    
    If filePath = "" Then
        MsgBox "Sheet1 の D1 にファイルパスが入っていません。", vbExclamation
        GoTo SAFE_EXIT
    End If
    
    If Dir(filePath) = "" Then
        MsgBox "ファイルが見つかりません。" & vbCrLf & filePath, vbExclamation
        GoTo SAFE_EXIT
    End If
    
    '新建结果sheet
    newSheetName = GetNewResultSheetName(wbThis)
    Set wsOut = wbThis.Sheets.Add(After:=wbThis.Sheets(wbThis.Sheets.Count))
    wsOut.Name = newSheetName
    
    wsOut.Cells(1, 1).Value = "IF文件ID"
    wsOut.Cells(1, 2).Value = "目录"
    wsOut.Cells(1, 3).Value = "详细结果"
    
    outRow = 2
    
    '打开目标文件
    Set wbSrc = Workbooks.Open(filePath, ReadOnly:=True)
    Set wsIndex = wbSrc.Sheets(1)   '目录页
    Set wsDetail = wbSrc.Sheets(2)  '详细页
    
    lastRowInput = wsInput.Cells(wsInput.Rows.Count, "A").End(xlUp).Row
    
    Set dictIfCount = CreateObject("Scripting.Dictionary")
    
    For i = 2 To lastRowInput
        
        ifID = Trim(CStr(wsInput.Cells(i, "A").Value))
        
        If ifID <> "" Then
            
            '当前 IFID 在输入表中是第几次出现
            If dictIfCount.Exists(ifID) Then
                dictIfCount(ifID) = dictIfCount(ifID) + 1
            Else
                dictIfCount.Add ifID, 1
            End If
            
            occurIndex = dictIfCount(ifID)
            
            '按第 N 次出现，取目录中的第 N 个“受信”结果
            dirText = FindNthDirectoryText(wsIndex, ifID, occurIndex, True)
            
            codeText = ""
            detailPath = ""
            
            If dirText <> "" Then
                codeText = GetCodeFromDirectoryText(dirText)
                
                If codeText <> "" Then
                    '详细页里先取这个 code 的第1个 Name:/...
                    detailPath = FindNamePathByCodeNth(wsDetail, codeText, 1)
                End If
            End If
            
            wsOut.Cells(outRow, 1).Value = ifID
            wsOut.Cells(outRow, 2).Value = dirText
            wsOut.Cells(outRow, 3).Value = detailPath
            
            outRow = outRow + 1
        End If
    Next i
    
    wbSrc.Close SaveChanges:=False
    
    wsOut.Columns("A:C").AutoFit
    
    MsgBox "検索完了。結果シート：" & wsOut.Name, vbInformation
    
SAFE_EXIT:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.DisplayAlerts = True
    Exit Sub

ERR_HANDLE:
    MsgBox "エラー：" & Err.Description, vbExclamation
    On Error Resume Next
    If Not wbSrc Is Nothing Then wbSrc.Close SaveChanges:=False
    
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.DisplayAlerts = True
End Sub


'====================================================
' 按输入顺序，找目录中第 nth 个匹配结果
' isReceive = True  -> 只取受信
' isReceive = False -> 只取送信
'====================================================
Private Function FindNthDirectoryText(ByVal ws As Worksheet, ByVal ifID As String, ByVal nth As Long, ByVal isReceive As Boolean) As String
    
    Dim rng As Range
    Dim c As Range
    Dim txt As String
    Dim hitCount As Long
    
    Set rng = ws.UsedRange
    hitCount = 0
    
    For Each c In rng.Cells
        If Not IsError(c.Value) Then
            txt = Trim(CStr(c.Value))
            
            If txt <> "" Then
                If InStr(1, txt, ifID, vbTextCompare) > 0 Then
                    
                    If isReceive = True Then
                        '只取受信，不要送信
                        If InStr(1, txt, "受信", vbTextCompare) > 0 _
                           And InStr(1, txt, "送信", vbTextCompare) = 0 Then
                            
                            hitCount = hitCount + 1
                            If hitCount = nth Then
                                FindNthDirectoryText = txt
                                Exit Function
                            End If
                        End If
                    Else
                        '只取送信，不要受信
                        If InStr(1, txt, "送信", vbTextCompare) > 0 _
                           And InStr(1, txt, "受信", vbTextCompare) = 0 Then
                            
                            hitCount = hitCount + 1
                            If hitCount = nth Then
                                FindNthDirectoryText = txt
                                Exit Function
                            End If
                        End If
                    End If
                    
                End If
            End If
        End If
    Next c
    
    FindNthDirectoryText = ""
    
End Function


'====================================================
' 从目录字符串中提取 code
' 例：
' N-SB11-H-S0011 - 【HULFT受信時処理 IFSB11009】
' -> N-SB11-H-S0011
'====================================================
Private Function GetCodeFromDirectoryText(ByVal txt As String) As String
    
    Dim p As Long
    
    txt = Trim(txt)
    p = InStr(txt, " - ")
    
    If p > 0 Then
        GetCodeFromDirectoryText = Trim(Left(txt, p - 1))
    Else
        GetCodeFromDirectoryText = ""
    End If
    
End Function


'====================================================
' 在详细页中查找第 nth 个 Name:/...code
'====================================================
Private Function FindNamePathByCodeNth(ByVal ws As Worksheet, ByVal codeText As String, ByVal nth As Long) As String
    
    Dim rng As Range
    Dim found As Range
    Dim firstAddr As String
    Dim cellText As String
    Dim hitCount As Long
    
    Set rng = ws.UsedRange
    
    Set found = rng.Find(What:=codeText, _
                         LookIn:=xlValues, _
                         LookAt:=xlPart, _
                         SearchOrder:=xlByRows, _
                         SearchDirection:=xlNext, _
                         MatchCase:=False)
    
    If found Is Nothing Then
        FindNamePathByCodeNth = ""
        Exit Function
    End If
    
    firstAddr = found.Address
    hitCount = 0
    
    Do
        cellText = Trim(CStr(found.Value))
        
        If LCase(Left(cellText, 5)) = "name:" Then
            hitCount = hitCount + 1
            
            If hitCount = nth Then
                FindNamePathByCodeNth = cellText
                Exit Function
            End If
        End If
        
        Set found = rng.FindNext(found)
        If found Is Nothing Then Exit Do
        
    Loop While found.Address <> firstAddr
    
    FindNamePathByCodeNth = ""
    
End Function


'====================================================
' 生成新的结果sheet名
' result_001, result_002 ...
'====================================================
Private Function GetNewResultSheetName(ByVal wb As Workbook) As String
    
    Dim i As Long
    Dim nm As String
    
    For i = 1 To 999
        nm = "result_" & Format(i, "000")
        If Not SheetExists(wb, nm) Then
            GetNewResultSheetName = nm
            Exit Function
        End If
    Next i
    
    GetNewResultSheetName = "result_999"
    
End Function


'====================================================
' 判断sheet是否存在
'====================================================
Private Function SheetExists(ByVal wb As Workbook, ByVal sheetName As String) As Boolean
    
    Dim ws As Worksheet
    
    On Error Resume Next
    Set ws = wb.Sheets(sheetName)
    SheetExists = Not ws Is Nothing
    Set ws = Nothing
    On Error GoTo 0
    
End Function
